generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String      @id @default(cuid())
  externalId        String      @unique
  name              String
  institution       String?
  institutionDomain String?
  currency          String      @default("USD")
  type              AccountType @default(CHECKING)
  balance           Decimal     @db.Decimal(15, 2)
  availableBalance  Decimal?    @db.Decimal(15, 2)
  balanceDate       DateTime
  isActive          Boolean     @default(true)
  backfillCursor    DateTime?
  backfillComplete  Boolean     @default(false)
  backfillUpdatedAt DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  transactions Transaction[]
  categoryRules CategoryRule[]
  goalAccounts GoalAccount[]
  loanDetails AccountLoanDetails?
  registeredDetails AccountRegisteredDetails?
  creditCardDetails AccountCreditCardDetails?
  netWorthSnapshots AccountNetWorthSnapshot[]
  assets Asset[]

  @@index([type])
  @@index([isActive])
}

model AccountLoanDetails {
  accountId                    String           @id
  account                      Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  loanType                     LoanType
  originalPrincipal            Decimal?         @db.Decimal(15, 2)
  currentPrincipal             Decimal?         @db.Decimal(15, 2)
  interestType                 InterestType?
  interestRateAnnual           Decimal?         @db.Decimal(7, 4)
  paymentAmount                Decimal?         @db.Decimal(15, 2)
  paymentFrequency             PaymentFrequency?
  termStartDate                DateTime?
  termMaturityDate             DateTime?
  originalAmortizationMonths   Int?
  remainingAmortizationMonths  Int?
  renewalDate                  DateTime?
  notes                        String?
  lastVerifiedAt               DateTime?
  source                       LoanDetailSource @default(USER_ENTERED)
  updatedBy                    String?
  createdAt                    DateTime         @default(now())
  updatedAt                    DateTime         @updatedAt

  @@index([loanType])
}

model AccountRegisteredDetails {
  accountId                String                     @id
  account                  Account                    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  registrationType         RegistrationType
  annualContributionLimit  Decimal                    @default(0) @db.Decimal(15, 2)
  totalContributionRoom    Decimal                    @default(0) @db.Decimal(15, 2)
  contributedThisYear      Decimal                    @default(0) @db.Decimal(15, 2)
  unusedCarryforward       Decimal                    @default(0) @db.Decimal(15, 2)
  beneficiaryName          String?
  beneficiaryDateOfBirth   DateTime?
  grantRoomAvailable       Decimal?                   @db.Decimal(15, 2)
  grantsReceived           Decimal?                   @db.Decimal(15, 2)
  subscriptionLimit        Decimal?                   @db.Decimal(15, 2)
  verificationSource       RegistrationVerificationSource @default(USER_ENTERED)
  lastVerifiedAt           DateTime
  notes                    String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  @@index([registrationType])
  @@index([lastVerifiedAt])
}

model AccountCreditCardDetails {
  accountId                String                         @id
  account                  Account                        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  creditLimit              Decimal                        @db.Decimal(15, 2)
  currentUtilization       Decimal                        @db.Decimal(5, 2)
  annualPercentageRate     Decimal                        @db.Decimal(7, 4)
  minimumPaymentDueDate    Int
  lastStatementBalance     Decimal                        @default(0) @db.Decimal(15, 2)
  lastStatementDate        DateTime?
  hasAnnualFee             Boolean                        @default(false)
  annualFeeAmount          Decimal?                       @db.Decimal(15, 2)
  rewardsProgram           CreditCardRewardsProgram?
  rewardsRate              Decimal?                       @db.Decimal(8, 4)
  rewardsRedeemedThisYear  Decimal?                       @db.Decimal(15, 2)
  issuingBank              String?
  cardType                 CreditCardType?
  verificationSource       CreditCardVerificationSource   @default(USER_ENTERED)
  lastVerifiedAt           DateTime
  notes                    String?
  createdAt                DateTime                       @default(now())
  updatedAt                DateTime                       @updatedAt

  @@index([lastVerifiedAt])
  @@index([currentUtilization])
}

model Transaction {
  id          String    @id @default(cuid())
  externalId  String    @unique
  accountId   String
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  posted      DateTime
  amount      Decimal   @db.Decimal(15, 2)
  description String
  payee       String?
  memo        String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryRuleId String?
  categoryRule CategoryRule? @relation(fields: [categoryRuleId], references: [id], onDelete: SetNull)
  isReviewed  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([accountId])
  @@index([categoryId])
  @@index([categoryRuleId])
  @@index([posted])
  @@index([accountId, posted])
}

model Category {
  id       String  @id @default(cuid())
  name     String  @unique
  icon     String?
  color    String?
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  transactions Transaction[]
  categoryRules CategoryRule[]
  budgets      Budget[]

  createdAt DateTime @default(now())

  @@index([parentId])
}

model CategoryRule {
  id                  String    @id @default(cuid())
  normalizedPayee     String
  categoryId          String
  category            Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  accountId           String?
  account             Account?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sourceTransactionId String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  transactions Transaction[]

  @@unique([normalizedPayee, accountId])
  @@index([normalizedPayee])
  @@index([categoryId])
}

model Budget {
  id         String       @id @default(cuid())
  categoryId String
  category   Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  amount     Decimal      @db.Decimal(15, 2)
  period     BudgetPeriod @default(MONTHLY)
  startDate  DateTime
  endDate    DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([categoryId])
}

model Report {
  id          String     @id @default(cuid())
  title       String
  type        ReportType
  content     Json
  period      String
  generatedAt DateTime   @default(now())

  @@index([type])
  @@index([period])
}

model SyncLog {
  id               String     @id @default(cuid())
  status           SyncStatus
  accountCount     Int        @default(0)
  transactionCount Int        @default(0)
  errorMessage     String?
  startedAt        DateTime   @default(now())
  completedAt      DateTime?

  @@index([status])
  @@index([startedAt])
}

model NetWorthSnapshot {
  id          String   @id @default(cuid())
  date        DateTime @unique
  totalAssets Decimal  @db.Decimal(15, 2)
  totalLiabilities Decimal @db.Decimal(15, 2)
  netWorth    Decimal  @db.Decimal(15, 2)
  createdAt   DateTime @default(now())

  @@index([date])
}

model AccountNetWorthSnapshot {
  id        String      @id @default(cuid())
  accountId String
  account   Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date      DateTime
  accountType AccountType
  balance   Decimal     @db.Decimal(15, 2)
  netWorth  Decimal     @db.Decimal(15, 2)
  createdAt DateTime    @default(now())

  @@unique([accountId, date])
  @@index([date])


}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  INVESTMENT
  LOAN
  MORTGAGE
  OTHER
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ReportType {
  MONTHLY_SUMMARY
  SPENDING_ANALYSIS
  NET_WORTH_TREND
  BUDGET_REVIEW
  PERSONAL_FINANCIAL_STATEMENT
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum AssetType {
  REAL_ESTATE
  AUTOMOBILE
  STOCK
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum LoanType {
  MORTGAGE
  AUTO_LOAN
  PERSONAL_LOAN
  HELOC
  OTHER
}

enum InterestType {
  FIXED
  VARIABLE
}

enum PaymentFrequency {
  WEEKLY
  BIWEEKLY
  SEMI_MONTHLY
  MONTHLY
}

enum LoanDetailSource {
  USER_ENTERED
  IMPORTED
  SYNCED
}

enum RegistrationType {
  RRSP
  TFSA
  RESP
  RIF
  RDSP
}

enum RegistrationVerificationSource {
  CRA_NOTICE_OF_ASSESSMENT
  INSTITUTION_STATEMENT
  USER_ENTERED
  IMPORTED
}

enum CreditCardRewardsProgram {
  NONE
  CASH_BACK
  POINTS
  MILES
  TRAVEL_CREDIT
}

enum CreditCardType {
  CREDIT
  CHARGE
  SECURED
}

enum CreditCardVerificationSource {
  INSTITUTION_STATEMENT
  USER_ENTERED
  SYNCED_FROM_ACCOUNT_AGGREGATOR
}

model Asset {
  id                String           @id @default(cuid())
  name              String
  type              AssetType        @default(REAL_ESTATE)
  purchasePrice     Decimal          @db.Decimal(15, 2)
  currentValue      Decimal          @db.Decimal(15, 2)
  purchaseDate      DateTime?
  address           String?
  metadata          Json?
  lastValuationDate DateTime?
  accountId         String?
  account           Account?         @relation(fields: [accountId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  valuations AssetValuation[]

  @@index([type])
  @@index([accountId])
}

model AssetValuation {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  value     Decimal  @db.Decimal(15, 2)
  source    String
  valuedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([assetId, valuedAt])
}

model Goal {
  id            String       @id @default(cuid())
  name          String
  targetAmount  Decimal      @db.Decimal(15, 2)
  currentAmount Decimal      @default(0) @db.Decimal(15, 2)
  targetDate    DateTime?
  status        GoalStatus   @default(ACTIVE)
  icon          String?
  color         String?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  accounts GoalAccount[]

  @@index([status])
}

model GoalAccount {
  id        String  @id @default(cuid())
  goalId    String
  goal      Goal    @relation(fields: [goalId], references: [id], onDelete: Cascade)
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([goalId, accountId])
  @@index([goalId])
  @@index([accountId])
}
